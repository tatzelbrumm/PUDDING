VERSION 5.7 ;
  NOWIREEXTENSIONATPIN ON ;
  DIVIDERCHAR "/" ;
  BUSBITCHARS "[]" ;
MACRO analog_wires
  CLASS BLOCK ;
  FOREIGN analog_wires ;
  ORIGIN 0.000 0.000 ;
  SIZE 99.600 BY 188.000 ;
  PIN VcascP[0]
    PORT
      LAYER Metal3 ;
        RECT 0.000 23.180 10.910 23.880 ;
    END
  END VcascP[0]
  PIN VcascP[1]
    PORT
      LAYER Metal3 ;
        RECT 0.000 39.550 10.910 40.250 ;
    END
  END VcascP[1]
  PIN Iout[0]
    PORT
      LAYER Metal3 ;
        RECT 0.000 31.365 21.910 32.065 ;
    END
  END Iout[0]
  PIN VDDA[0]
    PORT
      LAYER Metal3 ;
        RECT 0.000 24.280 20.700 26.010 ;
    END
  END VDDA[0]
  PIN VDDA[1]
    PORT
      LAYER Metal3 ;
        RECT 0.000 37.420 20.700 39.150 ;
    END
  END VDDA[1]
  PIN VbiasP[1]
    PORT
      LAYER Metal3 ;
        RECT 0.000 32.665 21.910 33.365 ;
    END
  END VbiasP[1]
  PIN VbiasP[0]
    PORT
      LAYER Metal3 ;
        RECT 0.000 30.065 21.910 30.765 ;
    END
  END VbiasP[0]
  PIN VcascP[2]
    PORT
      LAYER Metal3 ;
        RECT 0.000 151.460 10.910 152.160 ;
    END
  END VcascP[2]
  PIN VcascP[3]
    PORT
      LAYER Metal3 ;
        RECT 0.000 167.830 10.910 168.530 ;
    END
  END VcascP[3]
  PIN Iout[1]
    PORT
      LAYER Metal3 ;
        RECT 0.000 159.645 21.910 160.345 ;
    END
  END Iout[1]
  PIN VDDA[2]
    PORT
      LAYER Metal3 ;
        RECT 0.000 152.560 20.700 154.290 ;
    END
  END VDDA[2]
  PIN VDDA[3]
    PORT
      LAYER Metal3 ;
        RECT 0.000 165.700 20.700 167.430 ;
    END
  END VDDA[3]
  PIN VbiasP[3]
    PORT
      LAYER Metal3 ;
        RECT 0.000 160.945 21.910 161.645 ;
    END
  END VbiasP[3]
  PIN VbiasP[2]
    PORT
      LAYER Metal3 ;
        RECT 0.000 158.345 21.910 159.045 ;
    END
  END VbiasP[2]
  PIN i_in
    PORT
      LAYER Metal3 ;
        RECT 0.000 103.930 99.600 104.630 ;
    END
  END i_in
  PIN i_out
    PORT
      LAYER Metal3 ;
        RECT 0.000 95.745 99.600 96.445 ;
    END
  END i_out
  OBS
      LAYER GatPoly ;
        RECT 0.000 0.000 99.600 188.000 ;
      LAYER Metal1 ;
        RECT 1.400 0.000 99.600 188.000 ;
      LAYER Metal2 ;
        RECT 0.000 0.000 99.600 188.000 ;
      LAYER Metal3 ;
        RECT 1.700 0.000 97.300 188.000 ;
      LAYER Metal4 ;
        RECT 0.000 0.000 99.600 188.000 ;
      LAYER Metal5 ;
        RECT 0.000 0.000 99.600 188.000 ;
  END
END analog_wires
END LIBRARY

