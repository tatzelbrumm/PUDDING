VERSION 5.7 ;
  NOWIREEXTENSIONATPIN ON ;
  DIVIDERCHAR "/" ;
  BUSBITCHARS "[]" ;
MACRO analog_wires
  CLASS BLOCK ;
  FOREIGN analog_wires ;
  ORIGIN 0.000 0.000 ;
  SIZE 99.600 BY 188.000 ;
  PIN VcascP[2]
    PORT
      LAYER Metal3 ;
        RECT 0.000 112.560 10.910 113.260 ;
    END
  END VcascP[2]
  PIN VcascP[3]
    PORT
      LAYER Metal3 ;
        RECT 0.000 128.930 10.910 129.630 ;
    END
  END VcascP[3]
  PIN Iout[1]
    PORT
      LAYER Metal3 ;
        RECT 0.000 120.745 21.910 121.445 ;
    END
  END Iout[1]
  PIN VDDA[2]
    PORT
      LAYER Metal3 ;
        RECT 0.000 113.660 20.700 115.390 ;
    END
  END VDDA[2]
  PIN VDDA[3]
    PORT
      LAYER Metal3 ;
        RECT 0.000 126.800 20.700 128.530 ;
    END
  END VDDA[3]
  PIN VbiasP[3]
    PORT
      LAYER Metal3 ;
        RECT 0.000 122.045 21.910 122.745 ;
    END
  END VbiasP[3]
  PIN VbiasP[2]
    PORT
      LAYER Metal3 ;
        RECT 0.000 119.445 21.910 120.145 ;
    END
  END VbiasP[2]
  PIN VcascP[0]
    PORT
      LAYER Metal3 ;
        RECT 0.000 62.560 10.910 63.260 ;
    END
  END VcascP[0]
  PIN VcascP[1]
    PORT
      LAYER Metal3 ;
        RECT 0.000 78.930 10.910 79.630 ;
    END
  END VcascP[1]
  PIN Iout[0]
    PORT
      LAYER Metal3 ;
        RECT 0.000 70.745 21.910 71.445 ;
    END
  END Iout[0]
  PIN VDDA[0]
    PORT
      LAYER Metal3 ;
        RECT 0.000 63.660 20.700 65.390 ;
    END
  END VDDA[0]
  PIN VDDA[1]
    PORT
      LAYER Metal3 ;
        RECT 0.000 76.800 20.700 78.530 ;
    END
  END VDDA[1]
  PIN VbiasP[1]
    PORT
      LAYER Metal3 ;
        RECT 0.000 72.045 21.910 72.745 ;
    END
  END VbiasP[1]
  PIN VbiasP[0]
    PORT
      LAYER Metal3 ;
        RECT 0.000 69.445 21.910 70.145 ;
    END
  END VbiasP[0]
  PIN i_in
    PORT
      LAYER Metal3 ;
        RECT 0.000 103.930 99.600 104.630 ;
    END
  END i_in
  PIN i_out
    PORT
      LAYER Metal3 ;
        RECT 0.000 95.745 99.600 96.445 ;
    END
  END i_out
  OBS
      LAYER GatPoly ;
        RECT 0.000 0.000 99.600 188.000 ;
      LAYER Metal1 ;
        RECT 1.400 0.000 99.600 188.000 ;
      LAYER Metal2 ;
        RECT 0.000 0.000 99.600 188.000 ;
      LAYER Metal3 ;
        RECT 1.700 0.000 97.300 188.000 ;
      LAYER Metal4 ;
        RECT 0.000 0.000 99.600 188.000 ;
      LAYER Metal5 ;
        RECT 0.000 0.000 99.600 188.000 ;
  END
END analog_wires
END LIBRARY

