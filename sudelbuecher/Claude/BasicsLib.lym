<?xml version="1.0" encoding="utf-8"?>
<klayout-macro>
 <description>BasicsLib - FEOL contacts, PMOS buffer cap, PMOS cap array</description>
 <version/>
 <category>pymacros</category>
 <prolog/>
 <epilog/>
 <doc/>
 <autorun>true</autorun>
 <autorun-early>false</autorun-early>
 <priority>0</priority>
 <shortcut/>
 <show-in-menu>false</show-in-menu>
 <group-name/>
 <menu-path/>
 <interpreter>python</interpreter>
 <dsl-interpreter-name/>
 <text># -*- coding: utf-8 -*-
import pya


# ── PCell: feol_contact ───────────────────────────────────────────────────────
#
# A single row/column of contacts with an M1 landing bar.
# l and h are in nm (integers = DBU at dbu=0.001 µm).

class feol_contact(pya.PCellDeclarationHelper):

    def __init__(self):
        super().__init__()
        self.param("l",        self.TypeInt,   "contact length (nm)", default=260)
        self.param("h",        self.TypeInt,   "contact height (nm)", default=160)
        self.param("ly_active",self.TypeLayer, "Active (diffusion)",  default=pya.LayerInfo( 1, 0))
        self.param("ly_po",    self.TypeLayer, "Poly (Gate)",         default=pya.LayerInfo( 5, 0))
        self.param("ly_co",    self.TypeLayer, "Contact (CO)",        default=pya.LayerInfo( 6, 0))
        self.param("ly_m1",    self.TypeLayer, "Metal 1",             default=pya.LayerInfo( 8, 0))
        self.param("ly_pimp",  self.TypeLayer, "P+ implant",          default=pya.LayerInfo(14, 0))
        self.param("ly_nwell", self.TypeLayer, "N-Well",              default=pya.LayerInfo(31, 0))
        self.param("ly_pr",    self.TypeLayer, "Placement boundary",  default=pya.LayerInfo(63, 0))

    def display_text_impl(self):
        return f"feol_contact(l={self.l}nm, h={self.h}nm)"

    def coerce_parameters_impl(self):
        if self.l &lt;= 260: self.l = 260
        if self.h &lt;= 160: self.h = 160

    def produce_impl(self):
        ly_co = self.layout.layer(self.ly_co)
        ly_m1 = self.layout.layer(self.ly_m1)

        contact_size     = 160
        contact_distance = 180
        contact_pitch    = contact_size + contact_distance
        metal1endcap     =  50
        l = self.l
        h = self.h
        n_cuts_x = max(0, (l + contact_distance - 2 * metal1endcap) // contact_pitch)
        n_cuts_y = max(0, (h + contact_distance)                     // contact_pitch)
        xext     = n_cuts_x * contact_pitch - contact_distance
        yext     = n_cuts_y * contact_pitch - contact_distance
        start_x  = (l - xext) // 2
        start_y  = (h - yext) // 2
        for row in range(n_cuts_y):
            for col in range(n_cuts_x):
                xl = start_x + col * contact_pitch
                yb = start_y + row * contact_pitch
                self.cell.shapes(ly_co).insert(
                    pya.Box(xl, yb, xl + contact_size, yb + contact_size))
        self.cell.shapes(ly_m1).insert(pya.Box(0, 0, l, h))


# ── PCell: pmos_buffer_cap ────────────────────────────────────────────────────
#
# Single PMOS gate capacitor.
#   w_nm  = gate width  (nm, integer) — scales all y-dimensions and cell x-extent
#   l_nm  = gate length (nm, integer) — scales poly/gate-contact x-extent only
#
# Using nm integers (TypeInt) avoids KLayout's TypeDouble variant-cache bug
# where floating-point parameter changes fail to trigger cell regeneration.
#
# All offsets derived from pmosHV$2 mapped through rot90+mirrorX (W=L=8000nm ref):
#
#  Layer        cell-x (nm)                   cell-y (nm)
#  ─────────────────────────────────────────────────────────────────────────────
#  active main  [0,  w_nm]                    [0,  w_nm+680]
#  active src   [0,  w_nm]                    [-850, -550]   outer S/D tie
#  active drn   [0,  w_nm]                    [gate_y1+550, gate_y1+850]
#  poly  5/0    [gate_x0-790, gate_x1+110]    [gate_y0, gate_y1]  (incl gate arm)
#  poly  5/2    [-180, w_nm+180]              [gate_y0, gate_y1]  (channel pin)
#  M1 bus 8/0   [0,  w_nm]                    [-440, gate_y1+780]
#  M1 pin 8/2   [0,  w_nm]                    [70,  w_nm+610]
#  pimp  14/0   [-400, w_nm+400]              [gate_y0-520, gate_y1+520]
#  nwell 31/0   [-620, w_nm+620]              [gate_y0-1470, gate_y1+1470]
#  dnwell 44/0  same as nwell
#  gate cont 40 [0, 300]                      [gate_y1+40, gate_y1+340]
#  dev mark  51 [-180, w_nm+180]              [gate_y0, gate_y1]
#
#  gate_x0 = gate_y0 = 340 nm
#
#  FEOL contact bars (feol_contact pcell, length=w_nm, height=160nm):
#    source   at (0,          -440)             rot=0
#    drain    at (0,          gate_y1+620)      rot=0
#    gate-L   at (gate_x0-720, gate_y0)         rot=90, mirrorX
#    gate-R   at (gate_x1-120, gate_y0)         rot=90, mirrorX

class pmos_buffer_cap(pya.PCellDeclarationHelper):

    def __init__(self):
        super().__init__()
        # gate dimensions in nm (TypeInt avoids KLayout TypeDouble cache bug)
        self.param("w_nm",       self.TypeInt,   "Gate width  (nm)", default=8000)
        self.param("l_nm",       self.TypeInt,   "Gate length (nm)", default=8000)
        self.param("ly_active",  self.TypeLayer, "Active (diffusion)", default=pya.LayerInfo( 1, 0))
        self.param("ly_po",      self.TypeLayer, "Poly (Gate)",        default=pya.LayerInfo( 5, 0))
        self.param("ly_co",      self.TypeLayer, "Contact (CO)",       default=pya.LayerInfo( 6, 0))
        self.param("ly_m1",      self.TypeLayer, "Metal 1",            default=pya.LayerInfo( 8, 0))
        self.param("ly_pimp",    self.TypeLayer, "P+ implant",         default=pya.LayerInfo(14, 0))
        self.param("ly_nwell",   self.TypeLayer, "N-Well",             default=pya.LayerInfo(31, 0))
        self.param("ly_dnwell",  self.TypeLayer, "Deep N-Well",        default=pya.LayerInfo(44, 0))
        self.param("ly_gatecont",self.TypeLayer, "Gate cont marker",   default=pya.LayerInfo(40, 0))
        self.param("ly_devmark", self.TypeLayer, "Device marker",      default=pya.LayerInfo(51, 0))
        self.param("ly_polypin", self.TypeLayer, "Poly pin (5/2)",     default=pya.LayerInfo( 5, 2))
        self.param("ly_m1pin",   self.TypeLayer, "M1 pin (8/2)",       default=pya.LayerInfo( 8, 2))

    def display_text_impl(self):
        return f"pmos_buffer_cap(w={self.w_nm}nm, l={self.l_nm}nm)"

    def coerce_parameters_impl(self):
        if self.w_nm &lt; 500:  self.w_nm = 500
        if self.l_nm &lt; 500:  self.l_nm = 500

    def produce_impl(self):
        # all coordinates are in nm = DBU (dbu=0.001µm → 1DBU=1nm)

        def box(lyr, x1, y1, x2, y2):
            self.cell.shapes(lyr).insert(pya.Box(x1, y1, x2, y2))

        def place_feol(ox, oy, length_nm, rot=0, mirror=False):
            pcell_id   = self.layout.pcell_id("FEOL contacts")
            pcell_decl = self.layout.pcell_declaration("FEOL contacts")
            param_map  = {
                "l": length_nm, "h": 160,
                "ly_active": self.ly_active, "ly_po": self.ly_po,
                "ly_co":     self.ly_co,     "ly_m1": self.ly_m1,
            }
            params = [param_map.get(p.name, p.default)
                      for p in pcell_decl.get_parameters()]
            pcell_var = self.layout.add_pcell_variant(pcell_id, params)
            self.cell.insert(pya.CellInstArray(
                pcell_var, pya.CplxTrans(1.0, rot, mirror, ox, oy)))

        # resolve layers
        ly_active   = self.layout.layer(self.ly_active)
        ly_po       = self.layout.layer(self.ly_po)
        ly_polypin  = self.layout.layer(self.ly_polypin)
        ly_m1       = self.layout.layer(self.ly_m1)
        ly_m1pin    = self.layout.layer(self.ly_m1pin)
        ly_pimp     = self.layout.layer(self.ly_pimp)
        ly_nwell    = self.layout.layer(self.ly_nwell)
        ly_dnwell   = self.layout.layer(self.ly_dnwell)
        ly_gatecont = self.layout.layer(self.ly_gatecont)
        ly_devmark  = self.layout.layer(self.ly_devmark)

        w = self.w_nm    # gate width  in nm = DBU
        l = self.l_nm    # gate length in nm = DBU

        # fixed process offsets — all in nm
        gate_x0 =  340   # origin → gate left  edge
        gate_y0 =  340   # origin → gate bottom edge
        gate_x1 = gate_x0 + l
        gate_y1 = gate_y0 + w

        # ── active ───────────────────────────────────────────────────────
        box(ly_active,  0,    0,         w,   w + 680)   # main gate+S/D area
        box(ly_active,  0,  -850,        w,  -550)        # source tie
        box(ly_active,  0,   gate_y1+550, w,  gate_y1+850) # drain  tie

        # ── poly ─────────────────────────────────────────────────────────
        box(ly_po,      gate_x0-790,  gate_y0,  gate_x1+110,  gate_y1)  # drawing (incl arm)
        box(ly_polypin, -180,         gate_y0,  w+180,         gate_y1)  # pin (channel only)

        # ── M1 ───────────────────────────────────────────────────────────
        box(ly_m1,    0,  gate_y0-780,  w,  gate_y1+780)   # S/D bus
        box(ly_m1pin, 0,  70,           w,  w+610)          # pin markers

        # ── nwell / deep nwell ────────────────────────────────────────────
        box(ly_nwell,  -620, gate_y0-1470,  w+620, gate_y1+1470)
        box(ly_dnwell, -620, gate_y0-1470,  w+620, gate_y1+1470)

        # ── pimp ─────────────────────────────────────────────────────────
        box(ly_pimp,   -400, gate_y0-520,   w+400, gate_y1+520)

        # ── gate contact marker (layer 40) ────────────────────────────────
        box(ly_gatecont, 0, gate_y1+40,  300, gate_y1+340)

        # ── device marker (layer 51) ──────────────────────────────────────
        box(ly_devmark, -180, gate_y0,  w+180, gate_y1)

        # ── FEOL contact bars ─────────────────────────────────────────────
        place_feol(0,             gate_y0-780,  w)            # source
        place_feol(0,             gate_y1+620,  w)            # drain
        place_feol(gate_x0-720,  gate_y0,  w, rot=90, mirror=True)   # gate L
        place_feol(gate_x1-120,  gate_y0,  w, rot=90, mirror=True)   # gate R


# ── PCell: pmos_cap_array ─────────────────────────────────────────────────────
#
# 4 vertically stacked pmos_buffer_cap cells positioned within the dacbuffer
# wire frame.
#
# Parameter:
#   w_nm  gate width of each sub-cap (nm, integer)
#         cell x-extent = w_nm,  cell height = w_nm + 1700 nm,  gate l = w (square)
#
# Wire-frame positions (all in nm):
#   Iout M1  centre=13095nm  hw=350nm  top=13445nm
#   Top VSS  centre=25325nm  hw=865nm  bot=24460nm
#
# Design rules (nm):
#   m1_spacing     = 280   M1 min spacing
#   nwell_spacing  = 3105  x=0 to cap nwell left edge
#   nwell_ext_left =  620  cap nwell left overhang of cell origin
#   cap_m1_bot_ext =  440  cap M1 bottom below cell y-origin
#
# x_origin = 3725 nm,  y_base = 14165 nm,  pitch = w_nm + 1700

class pmos_cap_array(pya.PCellDeclarationHelper):

    def __init__(self):
        super().__init__()
        self.param("w_nm",       self.TypeInt,   "Gate width of each sub-cap (nm)", default=2000)
        self.param("ly_active",  self.TypeLayer, "Active (diffusion)", default=pya.LayerInfo( 1, 0))
        self.param("ly_po",      self.TypeLayer, "Poly (Gate)",        default=pya.LayerInfo( 5, 0))
        self.param("ly_co",      self.TypeLayer, "Contact (CO)",       default=pya.LayerInfo( 6, 0))
        self.param("ly_m1",      self.TypeLayer, "Metal 1",            default=pya.LayerInfo( 8, 0))
        self.param("ly_pimp",    self.TypeLayer, "P+ implant",         default=pya.LayerInfo(14, 0))
        self.param("ly_nwell",   self.TypeLayer, "N-Well",             default=pya.LayerInfo(31, 0))
        self.param("ly_dnwell",  self.TypeLayer, "Deep N-Well",        default=pya.LayerInfo(44, 0))
        self.param("ly_gatecont",self.TypeLayer, "Gate cont marker",   default=pya.LayerInfo(40, 0))
        self.param("ly_devmark", self.TypeLayer, "Device marker",      default=pya.LayerInfo(51, 0))
        self.param("ly_polypin", self.TypeLayer, "Poly pin (5/2)",     default=pya.LayerInfo( 5, 2))
        self.param("ly_m1pin",   self.TypeLayer, "M1 pin (8/2)",       default=pya.LayerInfo( 8, 2))

    def display_text_impl(self):
        return f"pmos_cap_array(w={self.w_nm}nm)"

    def coerce_parameters_impl(self):
        if self.w_nm &lt; 500: self.w_nm = 500

    def produce_impl(self):
        def place_cap(ox, oy):
            pcell_id   = self.layout.pcell_id("pmos_buffer_cap")
            pcell_decl = self.layout.pcell_declaration("pmos_buffer_cap")
            param_map  = {
                "w_nm":       self.w_nm,
                "l_nm":       self.w_nm,      # square gate
                "ly_active":  self.ly_active,
                "ly_po":      self.ly_po,
                "ly_co":      self.ly_co,
                "ly_m1":      self.ly_m1,
                "ly_pimp":    self.ly_pimp,
                "ly_nwell":   self.ly_nwell,
                "ly_dnwell":  self.ly_dnwell,
                "ly_gatecont":self.ly_gatecont,
                "ly_devmark": self.ly_devmark,
                "ly_polypin": self.ly_polypin,
                "ly_m1pin":   self.ly_m1pin,
            }
            params = [param_map.get(p.name, p.default)
                      for p in pcell_decl.get_parameters()]
            pcell_var = self.layout.add_pcell_variant(pcell_id, params)
            self.cell.insert(pya.CellInstArray(
                pcell_var, pya.CplxTrans(1.0, 0, False, ox, oy)))

        # all positions in nm
        iout_top   = 13095 + 350      # = 13445 nm
        m1_spacing =   280
        nw_left    =   620
        nw_spacing =  3105
        m1_bot_ext =   440

        x_origin   = nw_spacing + nw_left            # = 3725 nm
        y_base     = iout_top + m1_spacing + m1_bot_ext  # = 14165 nm
        pitch      = self.w_nm + 1700

        for n in range(4):
            place_cap(x_origin, y_base + n * pitch)


# ── Library registration ──────────────────────────────────────────────────────

class BasicsLib(pya.Library):
    def __init__(self):
        super().__init__()
        self.description = "BasicsLib – FEOL contacts, PMOS buffer cap, PMOS cap array"
        self.layout().register_pcell("FEOL contacts",   feol_contact())
        self.layout().register_pcell("pmos_buffer_cap", pmos_buffer_cap())
        self.layout().register_pcell("pmos_cap_array",  pmos_cap_array())
        self.register("BasicsLib")

BasicsLib()
</text>
</klayout-macro>